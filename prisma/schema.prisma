generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  ANNOUNCED
  ON_SALE
  SOLD_OUT
  CANCELLED
}

enum TicketLinkType {
  OFFICIAL
  RESALE
  FANCLUB
}

enum UserRole {
  USER
  ADMIN
}

enum PostKind {
  GENERAL
  MEETUP
  FAN_PROJECT
  WATCH_PARTY
  TICKETING
}

model Artist {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  nameKo      String?
  coverImage  String?
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tours       Tour[]
  events      Event[]
  follows     ArtistFollow[]
  posts       Post[]
}

model Tour {
  id          String   @id @default(cuid())
  artistId    String
  slug        String   @unique
  name        String
  year        Int?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  events      Event[]
}

model Venue {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  city       String
  country    String
  timezone   String?
  address    String?
  latitude   Decimal?
  longitude  Decimal?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  events     Event[]
}

model Event {
  id              String           @id @default(cuid())
  slug            String           @unique
  artistId        String
  tourId          String?
  venueId         String
  title           String
  description     String?
  startAt         DateTime
  endAt           DateTime?
  status          EventStatus
  sourceLabel     String
  sourceUrl       String?
  purchaseHint    String?
  doorsTime       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  artist          Artist           @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tour            Tour?            @relation(fields: [tourId], references: [id], onDelete: SetNull)
  venue           Venue            @relation(fields: [venueId], references: [id], onDelete: Restrict)
  ticketLinks     TicketLink[]
  sourceSnapshots SourceSnapshot[]
  favorites       FavoriteEvent[]
  posts           Post[]
}

model TicketLink {
  id         String         @id @default(cuid())
  eventId     String
  label       String
  href        String
  type        TicketLinkType
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model SourceSnapshot {
  id          String   @id @default(cuid())
  eventId      String
  sourceType   String
  sourceLabel  String
  sourceUrl    String?
  capturedAt   DateTime @default(now())
  rawPayload   Json?
  normalized   Json?
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String
  role           UserRole        @default(USER)
  bio            String?
  city           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       Session[]
  favoriteEvents FavoriteEvent[]
  follows        ArtistFollow[]
  posts          Post[]
  comments       Comment[]
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FavoriteEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model ArtistFollow {
  id        String   @id @default(cuid())
  userId    String
  artistId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId])
}

model Post {
  id         String    @id @default(cuid())
  slug       String    @unique
  title      String
  body       String
  kind       PostKind  @default(GENERAL)
  city       String?
  eventId     String?
  artistId    String?
  authorId    String
  pinned     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event       Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  artist      Artist?   @relation(fields: [artistId], references: [id], onDelete: SetNull)
  comments    Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  postId     String
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
